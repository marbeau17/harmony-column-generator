# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro-latest
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CTA_URL=https://harmony-booking.web.app/

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-TH2XJ24V3T
NEXT_PUBLIC_GTM_ID=GT-W6KD34W3

# Logging
LOG_LEVEL=DEBUG

# FTP Deploy
FTP_HOST=harmony-mc.com
FTP_USER=
FTP_PASSWORD=
FTP_PORT=21
FTP_REMOTE_PATH=/public_html/column/columns/

# Publish Control V2 — feature flags
# サーバ側で API ルート (/api/articles/[id]/visibility) を有効化
PUBLISH_CONTROL_V2=on
# FTP soft-withdrawal + hub rebuild を実通信
PUBLISH_CONTROL_FTP=on
# 新 PublishButton UI（クライアント側、ビルド時 inline）
NEXT_PUBLIC_PUBLISH_CONTROL_V2=on

# Dangling-deploying 自動回復（cron 用、Vercel + GitHub Actions に同値設定）
DANGLING_RECOVERY_TOKEN=

# Slack 通知 (live_hub_stale 検知時)。未設定なら no-op
SLACK_WEBHOOK_URL=

# Monkey/E2E test config — 本番では絶対に true にしない
MONKEY_TEST=false
FTP_DRY_RUN=false
# Monkey 専用 Supabase URL（dev/staging プロジェクトのみ）
MONKEY_SUPABASE_URL=http://127.0.0.1:54321
MONKEY_SUPABASE_SERVICE_ROLE=
MONKEY_BASE_URL=http://localhost:3000
MONKEY_SEED=1
# E2E テストユーザのパスワード（dev/staging のみ）
TEST_USER_PASSWORD=
TEST_USER_EMAIL=marbeau17@gmail.com
TEST_BASE_URL=http://localhost:3000

# ─── 公開 URL 設定 (P5-44 / P5-45) ────────────────────────────────
# 公開サイト (Apache/lolipop) のホストとベースパス。
# FTP_REMOTE_PATH と整合性を保つ必要あり (生成 HTML 内の URL ↔ 実 FTP 配置)。
#
# 現状運用 (P5-45 で /spiritual/column → /column に変更):
#   NEXT_PUBLIC_SITE_URL=https://harmony-mc.com
#   NEXT_PUBLIC_HUB_PATH=/column
#   FTP_REMOTE_PATH=/column/
#
# → 公開 URL: https://harmony-mc.com/column/{slug}/
#
# WordPress (root) の .htaccess catch-all は実ファイル/ディレクトリ存在時に
# バイパスされるので、/column/{slug}/index.html 物理配置で直接 200 配信される。
NEXT_PUBLIC_SITE_URL=https://harmony-mc.com
NEXT_PUBLIC_HUB_PATH=/column
